    "0": {
      "left": [
        "power",
        "workspaces"
      ],
      "middle": [
        "clock",
        "submap"
      ],
      "right": [
        "systray",
        "network",
        "bluetooth",
        "volume",
        "battery",
        "notifications"
      ]
    },
    "*": {
      "left": [
        "power",
        "workspaces"
      ],
      "middle": [
        "clock",
        "submap"
      ],
      "right": [
        "systray",
        "network",
        "bluetooth",
        "volume",
        "battery",
        "notifications"
      ]
    }
  },
