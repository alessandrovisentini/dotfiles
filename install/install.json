{
  "version": "1.0",
  "repository": {
    "url": "https://github.com/alessandrovisentini/dotfiles.git",
    "target_dir": "$HOME/Development/repos/dotfiles"
  },
  "os": {
    "nixos": {
      "config_symlinks": [
        "alacritty",
        "dunst",
        "git",
        "glow",
        "lazygit",
        "nvim",
        "rofi",
        "sway",
        "swaylock",
        "tmux",
        "waybar"
      ],
      "nixos_symlinks": {
        "enabled": true,
        "source_dir": "nixos",
        "target_dir": "/etc/nixos",
        "exclude": ["hardware-configuration.nix"]
      },
      "post_install": [
        "echo 'Run: sudo nixos-rebuild switch'"
      ]
    },
    "macos": {
      "config_symlinks": [
        "alacritty",
        "git",
        "glow",
        "lazygit",
        "nvim",
        "shell",
        "tmux"
      ],
      "nixos_symlinks": {
        "enabled": false
      },
      "packages": {
        "homebrew": {
          "taps": ["FelixKratz/formulae"],
          "formulae": [
            "neovim",
            "tmux",
            "lazygit",
            "glow",
            "ripgrep",
            "fd",
            "fzf",
            "sketchybar"
          ],
          "casks": ["alacritty", "amethyst", "scroll-reverser"]
        }
      },
      "post_install": [
        "$HOME/Development/repos/dotfiles/config/macos/defaults.sh"
      ]
    },
    "linux": {
      "config_symlinks": [
        "alacritty",
        "git",
        "glow",
        "lazygit",
        "nvim",
        "shell",
        "tmux"
      ],
      "nixos_symlinks": {
        "enabled": false
      },
      "packages": {
        "apt": [
          "neovim",
          "tmux",
          "ripgrep",
          "fd-find",
          "fzf"
        ],
        "dnf": [
          "neovim",
          "tmux",
          "ripgrep",
          "fd-find",
          "fzf"
        ],
        "pacman": [
          "neovim",
          "tmux",
          "lazygit",
          "glow",
          "ripgrep",
          "fd",
          "fzf"
        ]
      },
      "post_install": []
    }
  }
}
