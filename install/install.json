{
  "version": "2.1",
  "repository": {
    "url": "https://github.com/alessandrovisentini/dotfiles.git",
    "target_dir": "$HOME/Development/repos/dotfiles"
  },
  "os": {
    "nixos": {
      "config_symlinks": [
        "alacritty",
        "astal-bar",
        "git",
        "glow",
        "lazygit",
        "nvim",
        "rofi",
        "sway",
        "swaync",
        "tmux",
        "wm-scripts"
      ],
      "nixos_symlinks": {
        "enabled": true,
        "source_dir": "nixos",
        "target_dir": "/etc/nixos",
        "exclude": ["hardware-configuration.nix", "device.nix"]
      },
      "post_install": []
    },
    "macos": {
      "config_symlinks": [
        "alacritty",
        "git",
        "glow",
        "lazygit",
        "nvim",
        "shell",
        "sketchybar",
        "tmux"
      ],
      "nixos_symlinks": {
        "enabled": false
      },
      "packages": {
        "homebrew": {
          "taps": ["FelixKratz/formulae"],
          "formulae": [
            "neovim",
            "tmux",
            "lazygit",
            "glow",
            "ripgrep",
            "fd",
            "fzf",
            "nvm",
            "sketchybar",
            "tree-sitter",
            "markdownlint-cli",
            "go",
            "git-delta"
          ],
          "casks": ["alacritty", "iterm2", "amethyst", "scroll-reverser", "font-dejavu-sans-mono-nerd-font", "firefox", "claude-code"]
        }
      },
      "post_install": [
        "$HOME/Development/repos/dotfiles/config/macos/defaults.sh"
      ]
    },
    "fedora": {
      "config_symlinks": {
        "common": [
          "alacritty",
          "git",
          "glow",
          "lazygit",
          "nvim",
          "shell",
          "tmux"
        ],
        "gnome": [],
        "sway": [
          "astal-bar",
          "rofi",
          "sway",
          "swaync",
          "wm-scripts"
        ]
      },
      "nixos_symlinks": {
        "enabled": false
      },
      "gnome_dconf": {
        "enabled": true,
        "source": "config/gnome/dconf-settings.ini",
        "path": "/"
      },
      "gnome_extensions": {
        "enabled": true,
        "ego": [
          { "uuid": "simple-workspaces-bar@null-git",           "ext_id": 6394 },
          { "uuid": "disable-workspace-switcher-overlay@cleardevice", "ext_id": 6358 }
        ],
        "local": [
          { "uuid": "move-without-follow@local", "source": "nixos/extensions/move-without-follow" }
        ],
        "enable": [
          "appindicatorsupport@rgcjonas.gmail.com",
          "simple-workspaces-bar@null-git",
          "disable-workspace-switcher-overlay@cleardevice",
          "move-without-follow@local"
        ]
      },
      "packages": {
        "dnf": {
          "rpm_repos": [
            "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm",
            "https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm"
          ],
          "copr": [
            "atim/lazygit"
          ],
          "common": [
            "git-delta",
            "python3",
            "geary",
            "deja-dup",
            "gnome-calendar",
            "telegram-desktop",
            "pdftk-java",
            "libreoffice",
            "f3d",
            "mpv",
            "imv",
            "gnome-system-monitor",
            "gnome-disk-utility",
            "yt-dlp",
            "vlc",
            "calibre",
            "gimp",
            "inkscape",
            "easyeffects",
            "qpwgraph",
            "mscore",
            "audacity",
            "pdfarranger",
            "firefox",
            "gnome-keyring",
            "nano",
            "wget",
            "htop",
            "fastfetch",
            "wl-clipboard",
            "wl-screenrec",
            "gcc",
            "bind-utils",
            "traceroute",
            "ripgrep",
            "fzf",
            "unzip",
            "tmux",
            "neovim",
            "tcpdump",
            "fwupd",
            "git",
            "git-lfs",
            "nodejs",
            "npm",
            "docker-compose",
            "glow",
            "jq",
            "moby-engine",
            "android-tools",
            "lazygit",
            "steam",
            "cups",
            "hplip",
            "avahi",
            "system-config-printer",
            "alacritty",
            "playerctl",
            "pulseaudio-utils",
            "adwaita-icon-theme",
            "nautilus",
            "gnome-calculator",
            "gnome-contacts",
            "gnome-font-viewer",
            "gnome-snapshot",
            "gnome-music",
            "papers",
            "deluge-gtk",
            "polkit",
            "pipewire",
            "pipewire-pulseaudio",
            "pipewire-alsa",
            "pipewire-jack-audio-connection-kit",
            "wireplumber",
            "bluez",
            "gvfs"
          ],
          "gnome": [
            "gnome-shell",
            "gnome-tweaks",
            "gnome-shell-extension-appindicator"
          ],
          "sway": [
            "sway",
            "gtklock",
            "swayidle",
            "rofi-wayland",
            "SwayNotificationCenter",
            "libnotify",
            "brightnessctl",
            "network-manager-applet",
            "pwvucontrol",
            "grim",
            "slurp",
            "ImageMagick",
            "blueman",
            "grimshot",
            "wl-mirror",
            "lisgd",
            "wtype",
            "squeekboard",
            "iio-sensor-proxy",
            "playerctl"
          ]
        },
        "flatpak": {
          "remotes": [
            {
              "name": "flathub",
              "url": "https://flathub.org/repo/flathub.flatpakrepo"
            }
          ],
          "packages": [
            "com.spotify.Client",
            "com.discordapp.Discord",
            "md.obsidian.Obsidian",
            "org.localsend.localsend_app",
            "com.vscodium.codium",
            "io.github.ungoogled_software.ungoogled_chromium",
            "me.proton.Pass",
            "org.torproject.torbrowser-launcher"
          ],
          "overrides": [
            {
              "app": "com.discordapp.Discord",
              "args": ["--socket=wayland", "--env=ELECTRON_OZONE_PLATFORM_HINT=auto"]
            }
          ]
        },
        "npm_global": [
          "@anthropic-ai/claude-code"
        ],
        "pip_user": [
          "spotdl"
        ]
      },
      "post_install": [
        "$HOME/Development/repos/dotfiles/install/install-fedora-nerd-font.sh"
      ]
    }
  }
}
