# NixOS System Configuration
/etc/nixos/hardware-configuration.nix
hardware-configuration.nix

# Per-machine device selector — symlink to one of nixos/devices/*.nix
/etc/nixos/device.nix
nixos/device.nix

# Per-machine sway selector — symlink to one of config/sway/devices/*.conf
config/sway/device.conf

# Nix build artifacts
/result
/nix/store/*
/nix/var/nix/db/*
/nix/var/nix/profiles/*
/nix/var/nix/gcroots/*
/nix/var/log/*
/nix/var/cache/*
/nix/var/spool/*
/var/lib/nixos/*
/var/log/*
/var/tmp/*

# Secrets and Sensitive Files
secrets/
*.key
*.pem
*.crt
*.enc
*.gpg
*.asc
*.kbx
*.sqlite
*.nixops

# Shell History and User-Specific Files
.bash_history
.zsh_history
.fish_history
.lesshst
.inputrc

# Editor and IDE Files
*.swp
*.swo
*.bak
*.tmp
*.~*
*.orig
.vscode/
.idea/
*.code-workspace
*.sublime-workspace
*.sublime-project

# User Cache and Logs
.cache/
.local/share/
.local/state/
.xsession-errors*
/tmp/
*~

# Lock Files and Dependencies
.lock
*.lock
!config/grinch/Cargo.lock
node_modules/
vendor/
**/lazy-lock.json

# OS Specific
.DS_Store

# AI
**/.claude/settings.local.json

# Python bytecode (mode-daemon.py is built by Nix, not run from the tree)
__pycache__/
*.pyc
